{
  // Hugo 템플릿 파일을 Go HTML 템플릿으로 인식
  "files.associations": {
    "*.html": "gohtml"
  },

  // Front Matter CMS 설정
  "frontMatter.framework.id": "hugo",
  "frontMatter.content.publicFolder": "static",
  "frontMatter.preview.host": "http://localhost:1313",

  // TOML 포맷팅
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },

  // Markdown 설정
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "strings": true
    }
  },

  // 파일 탐색기에서 불필요한 폴더 숨기기
  "files.exclude": {
    "public/": true,
    "resources/": true
  },
  "markdown.copyFiles.destination": {
    "content/posts/**/*.md": "images/${fileName}",
    "content/docs/**/*.md": "images/${fileName}"
  }
}